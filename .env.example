# development | production
APP_ENV=development

# true  - запускать Telegram long polling
# false - запускать только Fastify admin, удобно для локальной проверки админки
BOT_ENABLED=true

# Для локальной разработки использовать токен @zamerflow_dev_bot.
# Для production использовать отдельный production bot token на VPS.
BOT_TOKEN=

# Local development не должен подключаться к production SQLite.
DATABASE_PATH=./data/zamerflow-dev.sqlite

ADMIN_PORT=3001

# Telegram group/supergroup chat id for confirmed order cards.
# Use /chatid in the target group to get this value.
DISPATCH_CHAT_ID=

# DaData Clean Address. По умолчанию выключено для local development.
DADATA_ENABLED=false
DADATA_API_KEY=
DADATA_SECRET_KEY=
DADATA_TIMEOUT_MS=3000
